---
import House from "@lucide/astro/icons/house";
import Images from "@lucide/astro/icons/images";
import MessageCircle from "@lucide/astro/icons/message-circle";
import PackageSearch from "@lucide/astro/icons/package-search";
import PencilRuler from "@lucide/astro/icons/pencil-ruler";
import { products } from "@/data/products";
import { site, whatsappUrl } from "@/data/site";

const currentPath = Astro.url.pathname;
const generalMessage =
  "Halo Admin BAC, saya ingin konsultasi kebutuhan atribut kedinasan.";

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

const desktopNavItems = [
  { label: "Katalog", href: "/katalog/" },
  { label: "Custom Order", href: "/custom-order/" },
  { label: "Proses Produksi", href: "/proses-produksi/" },
  { label: "Tentang BAC", href: "/tentang-bac/" },
  { label: "Kontak", href: "/kontak/" },
];

const mobileNavItems = [
  { label: "Beranda", href: "/", icon: House },
  { label: "Katalog", href: "/katalog/", icon: PackageSearch },
  { label: "Custom", href: "/custom-order/", icon: PencilRuler },
  { label: "Galeri", href: "/galeri/", icon: Images },
  { label: "Kontak", href: "/kontak/", icon: MessageCircle },
];
---

<header class="site-header" id="site-header">
  <div class="announcement" id="site-announcement">
    <p>
      <span class="announcement-wide">{products.length} referensi produk BAC kini tersedia.</span>
      <span class="announcement-short">{products.length} produk tersedia.</span>
      <a href="/katalog/">Buka katalog</a>
    </p>
    <button class="announcement-close" id="announcement-close" type="button" aria-label="Tutup pengumuman">
      &times;
    </button>
  </div>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Beranda BAC">
      <img
        class="brand-logo-lockup"
        src="/brand/bac-lockup.webp"
        alt=""
        width="900"
        height="319"
        decoding="async"
      />
      <img
        class="brand-logo-monogram"
        src="/brand/bac-monogram.webp"
        alt=""
        width="512"
        height="441"
        decoding="async"
      />
      <span class="sr-only">{site.name} - {site.tagline}</span>
    </a>

    <nav class="desktop-nav" aria-label="Navigasi utama">
      {
        desktopNavItems.map((item) => (
          <a class:list={[isActive(item.href) && "active"]} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <a class="button button-whatsapp header-cta" href={whatsappUrl(generalMessage)} target="_blank" rel="noreferrer">
      WhatsApp Admin
    </a>
  </div>
</header>

<nav class="mobile-bottom-nav" aria-label="Navigasi mobile bawah">
  {
    mobileNavItems.map((item) => (
      <a class:list={[isActive(item.href) && "active"]} href={item.href}>
        <item.icon class="mobile-nav-icon" size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>{item.label}</span>
      </a>
    ))
  }
</nav>

<script is:inline>
  (() => {
    const header = document.querySelector("#site-header");
    const closeButton = document.querySelector("#announcement-close");
    let lastScroll = window.scrollY;

    const updateHeader = () => {
      const currentScroll = window.scrollY;
      header?.classList.toggle("is-compact", currentScroll > 48 && currentScroll > lastScroll);
      lastScroll = currentScroll;
    };

    window.addEventListener("scroll", updateHeader, { passive: true });
    closeButton?.addEventListener("click", () => {
      header?.classList.add("is-dismissed");
      document.documentElement.style.setProperty("--announcement-height", "0px");
    });
  })();
</script>
