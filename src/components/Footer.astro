---
import { site, whatsappUrl } from "@/data/site";

const message = "Halo Admin BAC, saya ingin bertanya tentang katalog atribut kedinasan.";
---

<footer class="site-footer">
  <div class="container footer-statement">
    <p class="footer-statement-line">Atribut yang rapi, untuk identitas yang dibawa setiap hari.</p>
    <div class="footer-contact">
      <a class="footer-brand-logo" href="/" aria-label="Beranda BAC">
        <img
          src="/brand/bac-lockup.webp"
          alt=""
          width="900"
          height="319"
          loading="lazy"
          decoding="async"
        />
        <span class="sr-only">{site.name} - {site.tagline}</span>
      </a>
      <div class="footer-actions">
        <a href="/katalog/">Katalog</a>
        <a href="/tentang-bac/">Profil</a>
        <a href="/kontak/">Kontak</a>
        <a class="button button-whatsapp" href={whatsappUrl(message)} target="_blank" rel="noreferrer">
          Chat WhatsApp
        </a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>&copy; {new Date().getFullYear()} {site.name}</span>
    <span>{site.email}</span>
  </div>
</footer>
