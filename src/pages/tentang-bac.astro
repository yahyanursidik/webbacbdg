---
import ArrowRight from "@lucide/astro/icons/arrow-right";
import BadgeCheck from "@lucide/astro/icons/badge-check";
import BookOpenText from "@lucide/astro/icons/book-open-text";
import Boxes from "@lucide/astro/icons/boxes";
import Building2 from "@lucide/astro/icons/building-2";
import Factory from "@lucide/astro/icons/factory";
import MessageCircle from "@lucide/astro/icons/message-circle";
import PackageSearch from "@lucide/astro/icons/package-search";
import PencilRuler from "@lucide/astro/icons/pencil-ruler";
import Search from "@lucide/astro/icons/search";
import Store from "@lucide/astro/icons/store";
import Truck from "@lucide/astro/icons/truck";
import UserRound from "@lucide/astro/icons/user-round";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, whatsappUrl } from "@/data/site";

const audiences = [
  {
    title: "Pegawai instansi",
    description: "Mencari atribut seragam atau perlengkapan kedinasan untuk kebutuhan personal.",
    icon: UserRound,
    color: "blue",
  },
  {
    title: "Tim pengadaan",
    description: "Membutuhkan referensi produk dan jalur konsultasi untuk kebutuhan lembaga.",
    icon: Building2,
    color: "maroon",
  },
  {
    title: "Reseller & toko",
    description: "Mencari supplier untuk pembelian grosir dan pilihan produk yang beragam.",
    icon: Store,
    color: "green",
  },
  {
    title: "Pemesan custom",
    description: "Membawa desain atau kebutuhan khusus untuk ditinjau bersama admin BAC.",
    icon: PencilRuler,
    color: "gold",
  },
];

const commitments = [
  {
    title: "Katalog terstruktur",
    description: "Referensi produk dikelompokkan agar pencarian berdasarkan instansi dan jenis atribut lebih mudah.",
    icon: BookOpenText,
  },
  {
    title: "Pilihan pemenuhan",
    description: "Kebutuhan dapat diarahkan ke produk ready stock, pre-order, grosir, atau custom.",
    icon: PackageSearch,
  },
  {
    title: "Konsultasi langsung",
    description: "Detail produk, jumlah, referensi, dan target waktu dikonfirmasi bersama admin melalui WhatsApp.",
    icon: MessageCircle,
  },
  {
    title: "Pemeriksaan akhir",
    description: "Kesesuaian detail, jumlah, kondisi, dan kemasan diperiksa sebelum pesanan dikirim.",
    icon: BadgeCheck,
  },
];

const serviceFlow = [
  {
    title: "Kenali kebutuhan",
    description: "Tentukan instansi, jenis atribut, jumlah, atau kebutuhan custom.",
    icon: Search,
  },
  {
    title: "Lihat referensi",
    description: "Telusuri katalog atau kirim contoh produk yang dicari.",
    icon: BookOpenText,
  },
  {
    title: "Konfirmasi admin",
    description: "Ketersediaan dan detail penting dibahas sebelum diproses.",
    icon: MessageCircle,
  },
  {
    title: "Stok atau produksi",
    description: "Pesanan dipenuhi dari stok atau masuk jalur pre-order/custom.",
    icon: Factory,
  },
  {
    title: "QC & pengiriman",
    description: "Produk diperiksa, dikemas, lalu dikirim sesuai konfirmasi.",
    icon: Truck,
  },
];

const consultationMessage =
  "Halo Admin BAC, saya ingin konsultasi kebutuhan atribut kedinasan untuk personal, grosir, atau instansi.";
---

<BaseLayout
  title="Tentang BAC"
  description="Profil CV. Berkah Abadi Creative sebagai supplier atribut kedinasan untuk kebutuhan personal, grosir, pengadaan instansi, dan custom order."
  image="/images/bac-about-showroom.webp"
>
  <section class="page-hero about-page-hero">
    <img
      class="about-hero-background"
      src="/images/bac-about-showroom.webp"
      alt=""
      width="1672"
      height="941"
      fetchpriority="high"
      decoding="async"
    />
    <div class="container about-hero-content">
      <p class="about-hero-proof"><span aria-hidden="true"></span> Supplier atribut kedinasan</p>
      <h1>CV. Berkah Abadi Creative.</h1>
      <p>
        BAC membantu pelanggan personal, reseller, dan lembaga menemukan atribut kedinasan melalui
        katalog yang terstruktur, konsultasi langsung, serta pilihan ready stock, grosir, dan custom.
      </p>
      <div class="about-hero-actions">
        <a class="button button-light" href="/katalog/">
          <BookOpenText size={19} strokeWidth={1.9} aria-hidden="true" />
          Jelajahi Katalog
        </a>
        <a
          class="button button-whatsapp"
          href={whatsappUrl(consultationMessage)}
          target="_blank"
          rel="noreferrer"
        >
          <MessageCircle size={19} strokeWidth={1.9} aria-hidden="true" />
          Konsultasi BAC
        </a>
      </div>
      <p class="about-hero-caption">Gambaran suasana konsultasi dan pilihan produk BAC.</p>
    </div>
  </section>

  <nav class="about-anchor-nav" aria-label="Navigasi Tentang BAC">
    <div class="container">
      <a href="#profil-bac"><Building2 size={19} strokeWidth={1.8} aria-hidden="true" />Profil BAC</a>
      <a href="#pelanggan-bac"><UserRound size={19} strokeWidth={1.8} aria-hidden="true" />Pelanggan</a>
      <a href="#cara-melayani"><Factory size={19} strokeWidth={1.8} aria-hidden="true" />Cara melayani</a>
    </div>
  </nav>

  <section class="section about-profile-section" id="profil-bac">
    <div class="container about-profile-layout">
      <div class="about-profile-mark" aria-hidden="true">
        <span>B</span><span>A</span><span>C</span>
      </div>
      <div class="about-profile-copy">
        <p class="eyebrow">Profil perusahaan</p>
        <h2>Supplier yang menghubungkan kebutuhan dengan pilihan produk.</h2>
        <div class="about-profile-body">
          <p>
            {site.name} hadir sebagai distributor dan toko supplier atribut serta perlengkapan
            kedinasan. Pilihan produknya mencakup badge, emblem, patch bordir, pin, papan nama,
            tanda pengenal, dan perlengkapan seragam.
          </p>
          <p>
            BAC melayani pembelian satuan, grosir, kebutuhan pengadaan instansi, dan custom order.
            Website ini menjadi pusat katalog dan jalur konsultasi agar pelanggan dapat mengenali
            pilihan lebih dahulu sebelum menghubungi admin.
          </p>
        </div>
        <div class="about-profile-links">
          <a class="text-link" href="/proses-produksi/">
            Lihat proses produksi <ArrowRight size={17} strokeWidth={1.9} aria-hidden="true" />
          </a>
          <a class="text-link" href="/custom-order/">
            Pelajari custom order <ArrowRight size={17} strokeWidth={1.9} aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-soft about-audience-section" id="pelanggan-bac">
    <div class="container">
      <div class="section-head about-section-head">
        <div>
          <p class="eyebrow">Pelanggan BAC</p>
          <h2>Empat kebutuhan, satu jalur konsultasi.</h2>
        </div>
        <p>
          Informasi awal yang dibutuhkan dapat berbeda. Admin membantu mengarahkan kategori,
          ketersediaan, jumlah, dan proses pengerjaan yang sesuai.
        </p>
      </div>

      <div class="about-audience-grid">
        {
          audiences.map((audience, index) => (
            <article class={`about-audience-item about-audience-${audience.color}`}>
              <div class="about-audience-topline">
                <span class="about-audience-icon" aria-hidden="true">
                  <audience.icon size={27} strokeWidth={1.7} />
                </span>
                <small>{String(index + 1).padStart(2, "0")}</small>
              </div>
              <h3>{audience.title}</h3>
              <p>{audience.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section about-commitment-section">
    <div class="container about-commitment-layout">
      <div class="about-commitment-intro">
        <p class="eyebrow">Komitmen layanan</p>
        <h2>Informasi jelas sebelum pesanan berjalan.</h2>
        <p>
          BAC menempatkan katalog, konfirmasi kebutuhan, pilihan pemenuhan, dan pemeriksaan akhir
          sebagai bagian penting dari layanan.
        </p>
      </div>
      <ol class="about-commitment-list">
        {
          commitments.map((item, index) => (
            <li>
              <span class="about-commitment-icon" aria-hidden="true">
                <item.icon size={24} strokeWidth={1.7} />
              </span>
              <div>
                <small>{String(index + 1).padStart(2, "0")}</small>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section section-soft about-flow-section" id="cara-melayani">
    <div class="container">
      <div class="section-head about-section-head">
        <div>
          <p class="eyebrow">Cara BAC melayani</p>
          <h2>Dari kebutuhan hingga produk diterima.</h2>
        </div>
        <p>Alur menyesuaikan jenis pesanan, tetapi konfirmasi detail dan pemeriksaan akhir tetap menjadi titik penting.</p>
      </div>

      <ol class="about-flowchart" aria-label="Lima tahap layanan BAC">
        {
          serviceFlow.map((step, index) => (
            <li style={`--about-step: ${index};`}>
              <div class="about-flow-node">
                <step.icon size={25} strokeWidth={1.75} aria-hidden="true" />
                <span>{String(index + 1).padStart(2, "0")}</span>
              </div>
              <div class="about-flow-copy">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="about-cta-band">
    <div class="container about-cta-inner">
      <div>
        <p class="eyebrow">Mulai dari sini</p>
        <h2>Temukan produknya atau ceritakan kebutuhannya.</h2>
        <p>Katalog tersedia untuk eksplorasi mandiri. Admin BAC siap membantu kebutuhan yang lebih spesifik.</p>
      </div>
      <div class="about-cta-actions">
        <a class="button button-light" href="/katalog/">
          <Boxes size={19} strokeWidth={1.9} aria-hidden="true" />
          Buka Katalog
        </a>
        <a
          class="button button-whatsapp"
          href={whatsappUrl(consultationMessage)}
          target="_blank"
          rel="noreferrer"
        >
          <MessageCircle size={19} strokeWidth={1.9} aria-hidden="true" />
          Chat Admin BAC
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
