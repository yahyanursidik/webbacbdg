---
import ArrowRight from "@lucide/astro/icons/arrow-right";
import Building2 from "@lucide/astro/icons/building-2";
import MessageCircle from "@lucide/astro/icons/message-circle";
import PackageSearch from "@lucide/astro/icons/package-search";
import PencilRuler from "@lucide/astro/icons/pencil-ruler";
import Search from "@lucide/astro/icons/search";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import { categories, products } from "@/data/products";
import { site, whatsappUrl } from "@/data/site";

const consultationMessage = "Halo Admin BAC, saya ingin konsultasi kebutuhan atribut kedinasan.";
const procurementMessage =
  "Halo Admin BAC, saya ingin meminta informasi untuk kebutuhan grosir atau pengadaan instansi.";

const categoryCounts = products.reduce<Record<string, number>>((counts, product) => {
  counts[product.category] = (counts[product.category] ?? 0) + 1;
  return counts;
}, {});

const homeCategories = [...categories]
  .sort((a, b) => (categoryCounts[b.slug] ?? 0) - (categoryCounts[a.slug] ?? 0))
  .slice(0, 8);

const homeProductSlugs = [
  "polisi-pangkat-pdu-polisi-komisaris-jenderal",
  "jaksa-pangkat-pdh-jaksa-3a",
  "pemadam-emblem-pemadam",
  "sabuk-logo-daerah-sabuk-kabupaten-bandung-barat-kbb",
  "dishub-pin-dishub-corak-ak",
  "satpam-pin-kew-satpam-besar-anhas",
];
const homeProducts = homeProductSlugs
  .map((slug) => products.find((product) => product.slug === slug))
  .filter((product) => product !== undefined);

const heroProductSlugs = [
  "polisi-pangkat-pdu-polisi-komisaris-jenderal",
  "pemadam-emblem-pemadam",
  "atr-bpn-emblem-bpn",
];
const heroProducts = heroProductSlugs
  .map((slug) => products.find((product) => product.slug === slug))
  .filter((product) => product !== undefined);

const attributeTypeCount = new Set(products.map((product) => product.attributeType)).size;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: site.name,
  description: site.description,
  url: Astro.site?.toString(),
  email: site.email,
  address: site.address,
  openingHours: site.hours,
};
---

<BaseLayout
  title="BAC - Supplier Atribut Kedinasan & Kementerian Berkualitas"
  description={site.description}
  image="/catalog/polisi/polisi-pangkat-pdu-polisi-komisaris-jenderal-01.webp"
  schema={localBusinessSchema}
>
  <section class="hero home-hero">
    <div class="container hero-catalogue">
      <div class="hero-copy">
        <p class="brand-line">CV. Berkah Abadi Creative</p>
        <h1>Temukan atribut kedinasan yang tepat, lebih cepat.</h1>
        <p class="hero-lede">
          Cari koleksi asli BAC berdasarkan instansi, jabatan, pangkat, atau jenis atribut. Detail
          pesanan dikonfirmasi langsung bersama admin.
        </p>

        <form class="hero-search" action="/katalog/" method="get" role="search">
          <Search size={21} strokeWidth={1.9} aria-hidden="true" />
          <label class="sr-only" for="home-product-search">Cari produk BAC</label>
          <input
            id="home-product-search"
            name="q"
            type="search"
            placeholder="Contoh: pangkat polisi, pin jaksa, sabuk daerah"
            autocomplete="off"
          />
          <button type="submit" aria-label="Cari di katalog BAC">
            <span>Cari produk</span>
            <ArrowRight size={18} strokeWidth={2} aria-hidden="true" />
          </button>
        </form>

        <div class="hero-actions">
          <a class="button button-primary" href="/katalog/">
            <PackageSearch size={19} strokeWidth={1.9} aria-hidden="true" />
            Buka Katalog
          </a>
          <a
            class="button button-whatsapp"
            href={whatsappUrl(consultationMessage)}
            target="_blank"
            rel="noreferrer"
          >
            <MessageCircle size={19} strokeWidth={1.9} aria-hidden="true" />
            Chat WhatsApp
          </a>
        </div>

        <dl class="hero-ledger" aria-label="Ringkasan katalog BAC">
          <div><dt>{products.length}</dt><dd>Referensi produk</dd></div>
          <div><dt>{categories.length}</dt><dd>Kelompok instansi</dd></div>
          <div><dt>{attributeTypeCount}</dt><dd>Jenis atribut</dd></div>
        </dl>
      </div>

      <div class="hero-product-showcase" aria-label="Produk asli dari katalog BAC">
        {
          heroProducts.map((product, index) => (
            <a
              class:list={["hero-product-tile", index === 0 && "hero-product-main"]}
              href={`/katalog/${product.slug}/`}
            >
              <img
                src={product.image}
                alt={`Foto asli ${product.name}`}
                width="1200"
                height="1200"
                fetchpriority={index === 0 ? "high" : "auto"}
                decoding="async"
              />
              <span>
                <small>{product.institution}</small>
                <strong>{product.name}</strong>
              </span>
            </a>
          ))
        }
        <p class="showcase-note"><span aria-hidden="true"></span> Foto katalog BAC</p>
      </div>
    </div>
  </section>

  <section class="home-pathways" aria-labelledby="pathway-title">
    <div class="container">
      <div class="pathway-intro">
        <p class="eyebrow">Mulai dari kebutuhan Anda</p>
        <h2 id="pathway-title">Tiga jalur, satu admin yang membantu.</h2>
      </div>
      <div class="pathway-list">
        <a href="/katalog/">
          <PackageSearch size={24} strokeWidth={1.7} aria-hidden="true" />
          <span><strong>Cari produk tersedia</strong><small>Telusuri katalog berdasarkan instansi dan jenis.</small></span>
          <ArrowRight size={20} strokeWidth={1.8} aria-hidden="true" />
        </a>
        <a href={whatsappUrl(procurementMessage)} target="_blank" rel="noreferrer">
          <Building2 size={24} strokeWidth={1.7} aria-hidden="true" />
          <span><strong>Grosir & pengadaan</strong><small>Diskusikan jumlah, kebutuhan lembaga, dan penawaran.</small></span>
          <ArrowRight size={20} strokeWidth={1.8} aria-hidden="true" />
        </a>
        <a href="/custom-order/">
          <PencilRuler size={24} strokeWidth={1.7} aria-hidden="true" />
          <span><strong>Pesanan custom</strong><small>Kirim referensi untuk bahan, ukuran, atau desain khusus.</small></span>
          <ArrowRight size={20} strokeWidth={1.8} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <section class="section category-section" id="kategori-utama">
    <div class="container">
      <div class="section-head catalogue-head">
        <div>
          <p class="eyebrow">Direktori katalog</p>
          <h2>Cari berdasarkan instansi.</h2>
        </div>
        <div class="section-support">
          <p>Mulai dari kelompok dengan koleksi terbanyak, atau buka seluruh 17 kategori.</p>
          <a class="text-link" href="/katalog/#semua-kategori">
            Semua kategori <ArrowRight size={17} strokeWidth={1.9} aria-hidden="true" />
          </a>
        </div>
      </div>
      <div class="category-index home-category-index">
        {
          homeCategories.map((category, index) => (
            <a
              class="category-card home-category-card"
              href={`/katalog/?kategori=${category.slug}`}
              style={`--category-color: ${category.color}; --category-accent: ${category.accent};`}
            >
              <span class="category-number">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h3>{category.name}</h3>
                <p>{categoryCounts[category.slug]} produk</p>
              </div>
              <ArrowRight size={19} strokeWidth={1.8} aria-hidden="true" />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section product-section">
    <div class="container">
      <div class="section-head catalogue-head">
        <div>
          <p class="eyebrow">Produk lintas instansi</p>
          <h2>Lihat detail produk yang sebenarnya.</h2>
        </div>
        <div class="section-support">
          <p>Foto berikut berasal langsung dari koleksi katalog BAC yang telah diunggah.</p>
          <a class="text-link" href="/katalog/">
            Lihat seluruh katalog <ArrowRight size={17} strokeWidth={1.9} aria-hidden="true" />
          </a>
        </div>
      </div>
      <div class="product-grid">
        {homeProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section section-soft company-section">
    <div class="container company-layout">
      <div class="company-intro">
        <p class="eyebrow">Cara BAC membantu</p>
        <h2>Katalog jelas. Detail pesanan tetap manusiawi.</h2>
        <p>
          Produk atribut sering memiliki detail yang tidak cukup diputuskan dari foto. Admin BAC
          membantu mengonfirmasi spesifikasi sebelum pesanan diproses.
        </p>
        <a class="text-link" href="/tentang-bac/">
          Baca profil BAC <ArrowRight size={17} strokeWidth={1.9} aria-hidden="true" />
        </a>
      </div>
      <dl class="service-ledger">
        <div><dt>01 · Pilih</dt><dd>Cari produk melalui nama instansi, jabatan, pangkat, atau jenis atribut.</dd></div>
        <div><dt>02 · Tanyakan</dt><dd>Kirim produk pilihan ke WhatsApp tanpa perlu mengetik ulang namanya.</dd></div>
        <div><dt>03 · Konfirmasi</dt><dd>Pastikan bahan, ukuran, warna, ketersediaan, jumlah, dan waktu pengerjaan.</dd></div>
        <div><dt>04 · Proses</dt><dd>Pesanan disiapkan atau diproduksi, diperiksa, kemudian dikirim.</dd></div>
      </dl>
    </div>
  </section>

  <section class="custom-band">
    <div class="container custom-band-inner">
      <div>
        <p class="eyebrow">Kebutuhan khusus</p>
        <h2>Belum menemukan atribut yang dicari?</h2>
        <p>Kirim foto referensi, ukuran, bahan, dan jumlah. Tim BAC membantu menentukan opsinya.</p>
      </div>
      <a
        class="button button-light"
        href={whatsappUrl("Halo Admin BAC, saya ingin konsultasi custom order atribut.")}
        target="_blank"
        rel="noreferrer"
      >
        <MessageCircle size={19} strokeWidth={1.9} aria-hidden="true" />
        Konsultasi Custom
      </a>
    </div>
  </section>
</BaseLayout>
