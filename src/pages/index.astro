---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import { categories, featuredProducts } from "@/data/products";
import { site, whatsappUrl } from "@/data/site";

const consultationMessage = "Halo Admin BAC, saya ingin konsultasi kebutuhan atribut kedinasan.";
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: site.name,
  description: site.description,
  url: Astro.site?.toString(),
  email: site.email,
  address: site.address,
  openingHours: site.hours,
};
---

<BaseLayout
  title="BAC - Supplier Atribut Kedinasan & Kementerian Berkualitas"
  description={site.description}
  schema={localBusinessSchema}
>
  <section class="hero home-hero">
    <div class="container hero-catalogue">
      <div class="hero-copy">
        <p class="brand-line">CV. Berkah Abadi Creative</p>
        <h1>Atribut kedinasan untuk kebutuhan nyata.</h1>
        <p class="hero-lede">
          Katalog atribut instansi untuk pengadaan, reseller, dan custom. Pilih produk, lalu
          konsultasikan bahan, ukuran, dan jumlah dengan admin BAC.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/katalog/">Buka Katalog</a>
          <a class="button button-whatsapp" href={whatsappUrl(consultationMessage)} target="_blank" rel="noreferrer">
            Chat WhatsApp
          </a>
        </div>
        <dl class="hero-ledger" aria-label="Layanan utama BAC">
          <div><dt>Siap order</dt><dd>Satuan dan grosir</dd></div>
          <div><dt>Custom</dt><dd>Patch, badge, pin, emblem</dd></div>
          <div><dt>Konsultasi</dt><dd>Stok, bahan, ukuran, jumlah</dd></div>
        </dl>
      </div>
      <figure class="hero-visual">
        <img
          src="/images/bac-hero.webp"
          alt="Koleksi atribut kedinasan BAC"
          width="1536"
          height="1024"
          fetchpriority="high"
          decoding="async"
        />
        <figcaption>Supplier atribut kedinasan dan kementerian</figcaption>
        <div class="service-spectrum" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
      </figure>
    </div>
  </section>

  <section class="section category-section">
    <div class="container">
      <div class="section-head catalogue-head">
        <h2>Temukan berdasarkan instansi.</h2>
        <p>Warna membantu membedakan kelompok produk tanpa menggunakan lambang resmi.</p>
      </div>
      <div class="category-index">
        {
          categories.slice(0, 8).map((category, index) => (
            <a
              class="category-card"
              href={`/katalog/?kategori=${category.slug}`}
              style={`--category-color: ${category.color}; --category-accent: ${category.accent};`}
            >
              <span class="category-number">{String(index + 1).padStart(2, "0")}</span>
              <h3>{category.name}</h3>
              <p>{category.description}</p>
              <span class="category-link">Lihat produk <span aria-hidden="true">&rarr;</span></span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section product-section">
    <div class="container">
      <div class="section-head catalogue-head">
        <h2>Produk yang paling sering dicari.</h2>
        <a class="text-link" href="/katalog/">Lihat seluruh katalog <span aria-hidden="true">&rarr;</span></a>
      </div>
      <div class="product-grid">
        {featuredProducts.slice(0, 6).map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section section-soft company-section">
    <div class="container company-layout">
      <div class="company-intro">
        <h2>Katalog jelas. Detail pesanan tetap manusiawi.</h2>
        <p>
          BAC membantu tim pengadaan, pelanggan personal, reseller, toko seragam, sekolah kedinasan,
          dan lembaga pelatihan memilih atribut yang sesuai kebutuhan.
        </p>
        <a class="text-link" href="/tentang-bac/">Baca profil BAC <span aria-hidden="true">&rarr;</span></a>
      </div>
      <dl class="service-ledger">
        <div><dt>Katalog</dt><dd>Produk dikelompokkan berdasarkan kebutuhan instansi.</dd></div>
        <div><dt>Detail</dt><dd>Bahan, ukuran, warna, dan finishing dikonfirmasi sebelum diproses.</dd></div>
        <div><dt>Jumlah</dt><dd>Melayani kebutuhan satuan, grosir, reseller, dan pengadaan.</dd></div>
        <div><dt>Custom</dt><dd>Referensi khusus dapat dikonsultasikan langsung dengan admin.</dd></div>
      </dl>
    </div>
  </section>

  <section class="section order-section">
    <div class="container order-layout">
      <div>
        <h2>Empat langkah sampai pesanan dikirim.</h2>
        <img
          class="order-image"
          src="/images/bac-process.webp"
          alt="Meja proses produksi dan quality control atribut BAC"
          width="1536"
          height="1024"
          loading="lazy"
        />
      </div>
      <ol class="order-flow">
        <li><span>01</span><div><h3>Pilih produk</h3><p>Cari kategori atau produk yang sesuai kebutuhan.</p></div></li>
        <li><span>02</span><div><h3>Konsultasikan detail</h3><p>Admin membantu mengecek stok, bahan, ukuran, dan jumlah.</p></div></li>
        <li><span>03</span><div><h3>Konfirmasi pesanan</h3><p>Spesifikasi disepakati sebelum produksi atau penyiapan barang.</p></div></li>
        <li><span>04</span><div><h3>Terima pengiriman</h3><p>Produk diperiksa, dikemas, lalu dikirim ke alamat pelanggan.</p></div></li>
      </ol>
    </div>
  </section>

  <section class="custom-band">
    <div class="container custom-band-inner">
      <div>
        <h2>Punya desain atau spesifikasi khusus?</h2>
        <p>Kirim referensi, ukuran, bahan, dan jumlah. Tim BAC membantu menentukan opsi produksinya.</p>
      </div>
      <a class="button button-light" href={whatsappUrl("Halo Admin BAC, saya ingin konsultasi custom order atribut.")} target="_blank" rel="noreferrer">
        Bahas Custom Order
      </a>
    </div>
  </section>

  <section class="section location-section">
    <div class="container location-layout">
      <div>
        <h2>Kunjungi toko atau minta penawaran.</h2>
        <p>{site.address}</p>
        <p><strong>Jam operasional:</strong> {site.hours}</p>
        <div class="inline-actions">
          <a class="button button-primary" href="/alamat-toko/">Lihat Alamat</a>
          <a class="button button-secondary" href={site.mapsUrl} target="_blank" rel="noreferrer">Buka Maps</a>
        </div>
      </div>
      <iframe class="map-frame" src={site.mapsEmbed} loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Google Maps BAC"></iframe>
    </div>
  </section>
</BaseLayout>
