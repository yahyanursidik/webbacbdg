---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, whatsappUrl } from "@/data/site";
---

<BaseLayout
  title="Kontak"
  description="Hubungi BAC melalui WhatsApp, email, formulir inquiry, alamat toko, dan Google Maps."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Kontak</p>
      <h1>Hubungi BAC untuk produk, pengadaan, grosir, reseller, dan custom order.</h1>
      <p>
        Form inquiry di halaman ini mengirim ringkasan kebutuhan langsung ke WhatsApp admin BAC.
      </p>
      <a class="button button-whatsapp" href={whatsappUrl("Halo Admin BAC, saya ingin konsultasi kebutuhan atribut kedinasan.")} target="_blank" rel="noreferrer">
        WhatsApp Admin
      </a>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <form class="contact-panel contact-form" id="contact-form" data-phone={site.whatsappNumber}>
        <h2>Form Permintaan</h2>
        <label>
          Nama
          <input class="input" name="name" required placeholder="Nama lengkap" />
        </label>
        <label>
          Nomor WhatsApp
          <input class="input" name="whatsapp" required placeholder="08xxxxxxxxxx" />
        </label>
        <label>
          Instansi / kebutuhan
          <input class="input" name="institution" placeholder="Instansi, toko, reseller, atau personal" />
        </label>
        <label>
          Produk yang dicari
          <input class="input" name="product" required placeholder="Contoh: patch bordir, atribut Polri, pin" />
        </label>
        <label>
          Jumlah pesanan
          <input class="input" name="quantity" placeholder="Contoh: 10 pcs, 100 pcs, grosir" />
        </label>
        <label>
          Pesan tambahan
          <textarea class="textarea" name="message" placeholder="Detail bahan, ukuran, warna, atau deadline"></textarea>
        </label>
        <button class="button button-whatsapp" type="submit">Kirim ke WhatsApp</button>
      </form>

      <div class="contact-panel">
        <h2>Kontak Utama</h2>
        <p><strong>WhatsApp:</strong> <a href={whatsappUrl("Halo Admin BAC, saya ingin bertanya tentang katalog BAC.")} target="_blank" rel="noreferrer">Chat Admin BAC</a></p>
        <p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
        <p><strong>Alamat:</strong> {site.address}</p>
        <p><strong>Jam operasional:</strong> {site.hours}</p>
        <div class="inline-actions">
          <a class="button button-primary" href="/alamat-toko/">Alamat Toko</a>
          <a class="button button-secondary" href={site.mapsUrl} target="_blank" rel="noreferrer">Google Maps</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector("#contact-form");

    form?.addEventListener("submit", (event) => {
      event.preventDefault();

      if (!(form instanceof HTMLFormElement)) return;

      const data = new FormData(form);
      const phone = form.getAttribute("data-phone");
      const message = [
        "Halo Admin BAC, saya ingin mengirim permintaan penawaran:",
        "",
        `Nama: ${data.get("name") ?? ""}`,
        `Nomor WhatsApp: ${data.get("whatsapp") ?? ""}`,
        `Instansi / kebutuhan: ${data.get("institution") ?? ""}`,
        `Produk yang dicari: ${data.get("product") ?? ""}`,
        `Jumlah pesanan: ${data.get("quantity") ?? ""}`,
        `Pesan tambahan: ${data.get("message") ?? ""}`,
      ].join("\n");

      window.open(`https://wa.me/${phone}?text=${encodeURIComponent(message)}`, "_blank", "noopener,noreferrer");
    });
  </script>
</BaseLayout>
